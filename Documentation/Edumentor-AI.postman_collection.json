        {
          "name": "Signup - Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  const bearer = data.token || '';",
                  "  const jwt = bearer.replace(/^Bearer\\s+/i, '');",
                  "  pm.collectionVariables.set('jwtToken', jwt);",
                  "  pm.collectionVariables.set('authHeader', bearer);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
